{
  "expo": {
    "name": "MoneyMind",
    "slug": "MoneyMind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.png", 
    "scheme": "moneymind",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/Logo.jpeg"  // Para iOS
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#131925",  
        "foregroundImage": "./assets/images/Logo.png"  
      }
      
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.png",  // Logo para splash
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#131925" 
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}